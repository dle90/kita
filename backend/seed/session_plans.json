{
  "plans": {
    "quiz": {
      "kind": "review",
      "activities": [
        {"phase": "warmup",    "source": "srs_due",      "skill": "weakest",    "format": "auto",           "count": 3},
        {"phase": "recall",    "source": "srs_due",      "skill": "weakest",    "format": "auto",           "count": 4},
        {"phase": "phoneme",   "source": "phoneme_weak", "skill": "perception", "format": "phonics_listen", "count": 1},
        {"phase": "error",     "source": "error_focus",  "skill": "speaking",   "format": "speak_word",     "count": 1},
        {"phase": "fun_finish","source": "all_learned",  "skill": "auto",       "format": "word_match",     "count": 1}
      ]
    }
  },

  "selector": {
    "strategy": "fixed_cycle_with_triggers",
    "cycle": ["discovery", "story", "quiz", "story", "quiz", "performance", "play"],
    "triggers": [
      {"name": "cold_start",     "when": {"total_sessions_lt": 2},   "replace_with": "default"},
      {"name": "srs_backlog",    "when": {"srs_backlog_gt": 20},     "replace_with": "quiz"},
      {"name": "skill_weakness", "when": {"avg_skill_lt": 0.6},      "replace_with": "quiz"}
    ]
  },

  "default_plan": {
    "activities": [
      {"phase": "warmup",      "source": "srs_due",      "skill": "weakest",    "format": "auto",             "count": 2},
      {"phase": "warmup",      "source": "srs_due",      "skill": "listening",  "format": "listen_and_choose","count": 1},
      {"phase": "phonics",     "source": "phoneme_weak", "skill": "perception", "format": "phonics_listen",   "count": 1},
      {"phase": "phonics",     "source": "phoneme_weak", "skill": "production", "format": "phonics_match",    "count": 1},
      {"phase": "grammar",     "source": "grammar_next", "skill": "reading",    "format": "pattern_intro",    "count": 1},
      {"phase": "new_content", "source": "unit_vocab",   "skill": "listening",  "format": "flashcard_intro",  "count": 1},
